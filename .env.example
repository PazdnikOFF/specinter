# Postgres (новое доменное ядро)
PG_DB=specinter
PG_USER=specinter
PG_PASSWORD=specinter
PG_PORT=5432

# MariaDB (legacy, авто-загрузка дампа для анализа и ETL)
LEGACY_DB=specinter_legacy
LEGACY_ROOT_PASSWORD=root
LEGACY_PORT=3307

# Meilisearch (мгновенный поиск) + API
MEILI_KEY=specinter_dev_key
MEILI_PORT=7700
API_PORT=8010
WEB_PORT=3000
MEDIA_PORT=8081

# Приём прайсов с почты (IMAP). Пусто = воркер простаивает.
# Яндекс.Почта: IMAP_HOST=imap.yandex.ru, IMAP_USER=ящик@yandex.ru,
# IMAP_PASSWORD=пароль приложения (Яндекс ID → Безопасность → Пароли приложений, тип «Почта»),
# и включить IMAP в настройках Яндекс.Почты. Отправителей сопоставляем с поставщиками
# по suppliers.sender_email (задаётся в админке → Поставщики).
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX
POLL_INTERVAL=300

# Отправка писем «товар поступил в наличие» (подписки с карточки товара).
# Пусто = подписки принимаются и копятся, но письма НЕ уходят.
# Яндекс.Почта: SMTP_HOST=smtp.yandex.ru, SMTP_PORT=465, тот же пароль приложения.
# SMTP_FROM пустой = берётся SMTP_USER. SITE_URL нужен для ссылки на товар в письме.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SITE_URL=https://specinter.ru

# Прямая интеграция 1С:УНФ (пусто = dry-run режим). БЕЗ файлового обмена.
UNF_BASE_URL=
UNF_USER=
UNF_PASSWORD=
UNF_ODATA_PATH=/odata/standard.odata
UNF_HTTP_SERVICE_ROOT=/hs/specinter

# --- Платежи физлиц (пусто = dry-run) ---
PAY_PROVIDER=yookassa
PAY_RETURN_URL=http://localhost:3000/order/success
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
TINKOFF_TERMINAL_KEY=
TINKOFF_PASSWORD=

# --- ЭДО Контур.Диадок (пусто = dry-run) ---
DIADOC_API_CLIENT_ID=
DIADOC_TOKEN=
DIADOC_BOX_ID=

# --- ИИ-оператор (bot-gateway) ---
BOT_PORT=8090
# LLM: Grok (https://api.x.ai/v1, grok-4) или Hermes (OpenRouter/vLLM URL + модель)
LLM_BASE_URL=https://api.x.ai/v1
LLM_MODEL=grok-4
LLM_API_KEY=
LLM_TEMPERATURE=0.2
# Каналы
TELEGRAM_TOKEN=
MAX_TOKEN=
IG_ACCESS_TOKEN=
WA_TRANSPORT=cloud
WA_TOKEN=
WA_PHONE_ID=
WA_BRIDGE_URL=
WEBHOOK_VERIFY_TOKEN=specinter
# Автопостинг Instagram (рилсы/реклама)
IG_USER_ID=
IG_AD_ACCOUNT_ID=
MARKETING_ENABLED=0
MARKETING_INTERVAL=86400
REEL_LIBRARY=
PUBLIC_MEDIA_URL=

# Админка (логин/пароль) + секрет cookie
ADMIN_USER=admin
ADMIN_PASSWORD=specinter
ADMIN_SECRET=change-me-in-prod
CORS_ORIGINS=http://localhost:3000

# DaData (реквизиты по ИНН, геолокация): токен из dadata.ru. Пусто = dry-run
DADATA_TOKEN=
DADATA_SECRET=
# Деловые Линии (расчёт доставки): appkey из личного кабинета. Пусто = dry-run
DELLIN_APPKEY=
WAREHOUSE_CITY=Екатеринбург
# Ссылки ботов для каналов связи (публичные)
NEXT_PUBLIC_TG_BOT=
NEXT_PUBLIC_WA_NUMBER=
NEXT_PUBLIC_MAX_BOT=

# --- Прод: HTTPS/nginx (docker-compose.prod.yml) -------------------------
# Домен прод-сайта (резолвится на сервер, порты 80/443 доступны из интернета).
DOMAIN=specinter.example.ru
# E-mail для Let's Encrypt (уведомления об истечении).
LETSENCRYPT_EMAIL=admin@example.ru
# 1 = тестовый CA Let's Encrypt (для отладки, без лимитов); 0 = боевой.
LETSENCRYPT_STAGING=0
# В проде за HTTPS: origin API = сам домен (cookie-сессия админки, CORS).
# CORS_ORIGINS=https://specinter.example.ru
# Прод-безопасность: BIND_ADDR запирает api/postgres/meili/media/bot на localhost
# (наружу их порты не публикуются). Витрина web НЕ подчиняется BIND_ADDR — у неё
# отдельный WEB_BIND_ADDR (пусто = 0.0.0.0, доступ к сайту по LAN/интернету).
# Браузер ходит в бэкенд через /api и /media (веб-прокси), поэтому api/media снаружи не нужны.
# В dev/LAN оставить BIND_ADDR ПУСТЫМ (всё по IP). В проде без публичного HTTPS:
# BIND_ADDR=127.0.0.1:
# С reverse-proxy (80/443) можно и WEB_BIND_ADDR=127.0.0.1: (наружу только прокси).
# WEB_BIND_ADDR=
